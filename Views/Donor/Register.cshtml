@model BloodDonationApp.Models.Donor
@{
    ViewData["Title"] = "Register as Donor - Donora";
}

<div class="row justify-content-center py-4">
    <div class="col-md-7">
        <div class="card border-0 shadow-sm p-5" style="background-color: #FFFFFF; border: 1px solid #E8DDD5 !important; box-shadow: 0 2px 16px rgba(0,0,0,0.07) !important;">
            <h1 class="mb-2 text-center" style="font-family: 'Times New Roman', serif; color: #5C1A1A; font-weight: bold;">Become a Lifesaver</h1>
            <p class="text-muted text-center mb-4" style="color: #8C7B75 !important;">Register as a blood donor in the Donora database and help patients in need.</p>
            
            <form asp-action="Register" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                
                <div class="row">
                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="Name" class="control-label text-uppercase small fw-bold" style="color: #9B3A3A; letter-spacing: 1.5px;"></label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. John Doe" required />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    
                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="BloodType" class="control-label text-uppercase small fw-bold" style="color: #9B3A3A; letter-spacing: 1.5px;">Blood Type</label>
                        <select asp-for="BloodType" class="form-control" required>
                            <option value="">-- Select Blood Type --</option>
                            <option value="A+">A+</option>
                            <option value="A-">A-</option>
                            <option value="B+">B+</option>
                            <option value="B-">B-</option>
                            <option value="AB+">AB+</option>
                            <option value="AB-">AB-</option>
                            <option value="O+">O+</option>
                            <option value="O-">O-</option>
                        </select>
                        <span asp-validation-for="BloodType" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="Phone" class="control-label text-uppercase small fw-bold" style="color: #9B3A3A; letter-spacing: 1.5px;">Phone Number</label>
                        <input asp-for="Phone" class="form-control" placeholder="e.g. 9876543210" required />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>
                    
                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="Email" class="control-label text-uppercase small fw-bold" style="color: #9B3A3A; letter-spacing: 1.5px;"></label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="e.g. john@example.com" required />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="Password" class="control-label text-uppercase small fw-bold" style="color: #9B3A3A; letter-spacing: 1.5px;">Password</label>
                        <div class="input-group">
                            <input asp-for="Password" type="password" id="txtPassword" class="form-control" placeholder="••••••••" required />
                            <button class="btn btn-outline-secondary" type="button" id="btnTogglePassword" style="border: 1px solid rgba(155, 58, 58, 0.2); border-left: none;">
                                <i class="bi bi-eye-slash" id="eyeIcon"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    
                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="ConfirmPassword" class="control-label text-uppercase small fw-bold" style="color: #9B3A3A; letter-spacing: 1.5px;">Confirm Password</label>
                        <div class="input-group">
                            <input asp-for="ConfirmPassword" type="password" id="txtConfirmPassword" class="form-control" placeholder="••••••••" required />
                            <button class="btn btn-outline-secondary" type="button" id="btnToggleConfirmPassword" style="border: 1px solid rgba(155, 58, 58, 0.2); border-left: none;">
                                <i class="bi bi-eye-slash" id="confirmEyeIcon"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="City" class="control-label text-uppercase small fw-bold" style="color: #9B3A3A; letter-spacing: 1.5px;"></label>
                        <input asp-for="City" class="form-control" placeholder="e.g. Mumbai" required />
                        <span asp-validation-for="City" class="text-danger small"></span>
                    </div>
                    
                    <div class="col-md-6 form-group mb-4">
                        <label asp-for="LastDonationDate" class="control-label text-uppercase small fw-bold" style="color: #9B3A3A; letter-spacing: 1.5px;">Last Donation Date</label>
                        <input asp-for="LastDonationDate" class="form-control" type="date" />
                        <span asp-validation-for="LastDonationDate" class="text-danger small"></span>
                    </div>
                </div>

                <div class="form-group mt-3">
                    <button type="submit" class="btn btn-primary w-100 py-3 text-uppercase">Submit Registration</button>
                </div>
            </form>
            
            <div class="text-center mt-4">
                <p class="mb-0 text-muted small" style="color: #8C7B75 !important;">Already registered? <a asp-controller="Account" asp-action="UserLogin" style="color: #B5894A; text-decoration: none; font-weight: bold;">Sign in to your portal</a></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
