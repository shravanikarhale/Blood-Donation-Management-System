@model BloodDonationApp.Models.Donor
@{
    Layout = "_UserLayout";
    ViewData["Title"] = "Blood Donation Availability";
}

<div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
    <h1 style="font-family: 'Times New Roman', serif;">Donation Availability</h1>
    <a asp-action="Dashboard" class="btn btn-secondary btn-sm">&larr; Back to Dashboard</a>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm p-4">
            <h3 style="font-family: 'Times New Roman', serif;" class="mb-3 text-dark">Toggle Availability</h3>
            <p class="text-muted small">
                When you are marked as <strong>Available</strong>, patients and hospitals searching for your blood type in your city can view your name and phone number to contact you. If you are temporarily busy or ineligible, please toggle this off.
            </p>
            
            <form asp-action="Donate" method="post" class="mt-4">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.Id" />
                
                <div class="form-check form-switch mb-4 fs-5">
                    <input class="form-check-input" type="checkbox" name="isAvailable" id="isAvailableSwitch" value="true" @(Model.IsAvailable ? "checked" : "") />
                    <label class="form-check-label text-uppercase small fw-bold" for="isAvailableSwitch" style="color: #C0392B; letter-spacing: 1px;">
                        I am currently available to donate
                    </label>
                </div>
                
                <button type="submit" class="btn btn-primary w-100 py-2 text-uppercase">Save Availability Status</button>
            </form>
        </div>
    </div>
</div>
