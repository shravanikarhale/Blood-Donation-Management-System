@{
    ViewData["Title"] = "Our Story & Mission - Donora";
}

<!-- Hero Section -->
<div class="card p-5 mb-5 border-0 text-center" style="background: linear-gradient(135deg, #7D2B2B 0%, #5C1A1A 100%); border-bottom: 4px solid #B5894A !important; box-shadow: 0 4px 20px rgba(92, 26, 26, 0.15);">
    <div class="py-4">
        <h1 class="display-4 mb-3" style="font-family: 'Times New Roman', serif; color: #F5ECD7; font-weight: bold; letter-spacing: 2px;">THE DONORA MISSION</h1>
        <p class="lead mx-auto" style="max-width: 800px; color: #FBF7F0; font-family: Georgia, serif; font-size: 1.2rem; line-height: 1.8;">
            We believe that access to safe blood is a fundamental right. Donora is a premium digital bridge connecting altruistic donors with patients and medical institutions to save lives in real time.
        </p>
    </div>
</div>

<!-- Mission & Why Donate Cards -->
<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card h-100 p-4 text-center">
            <div style="font-size: 2.5rem;" class="mb-3">🎯</div>
            <h4 style="font-family: 'Times New Roman', serif; font-weight: bold;">Our Purpose</h4>
            <p class="text-muted small mb-0" style="color: #8C7B75 !important; line-height: 1.6;">
                To eliminate critical blood shortages by providing a transparent, efficient, and direct channel between willing donors and patients in urgent need.
            </p>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card h-100 p-4 text-center">
            <div style="font-size: 2.5rem;" class="mb-3">💖</div>
            <h4 style="font-family: 'Times New Roman', serif; font-weight: bold;">Why Give Blood?</h4>
            <p class="text-muted small mb-0" style="color: #8C7B75 !important; line-height: 1.6;">
                A single donation takes less than 15 minutes but can save up to three lives. It is the most direct, personal, and powerful gift of life you can ever offer.
            </p>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card h-100 p-4 text-center">
            <div style="font-size: 2.5rem;" class="mb-3">🛡️</div>
            <h4 style="font-family: 'Times New Roman', serif; font-weight: bold;">Safety First</h4>
            <p class="text-muted small mb-0" style="color: #8C7B75 !important; line-height: 1.6;">
                We promote safe donation intervals and strictly verify hospitals and requests to ensure the security, privacy, and health of our community.
            </p>
        </div>
    </div>
</div>

<!-- Horizontal Timeline Journey -->
<div class="my-5 py-4">
    <h2 class="text-center mb-5" style="font-family: 'Times New Roman', serif; font-weight: bold;">THE DONATION JOURNEY</h2>
    
    <div class="row g-3">
        <!-- Step 1 -->
        <div class="col-md-3">
            <div class="card p-4 h-100 step-card text-center border-0 shadow-sm" style="background-color: #FFFFFF; border: 1px solid #E8DDD5 !important;">
                <div class="mb-3">
                    <span class="step-number">1</span>
                </div>
                <h5 style="font-family: 'Times New Roman', serif; font-weight: bold; color: #5C1A1A;">Register</h5>
                <p class="text-muted small mb-0" style="color: #8C7B75 !important;">Create a profile, specify your blood group, and set your location.</p>
            </div>
        </div>
        
        <!-- Step 2 -->
        <div class="col-md-3">
            <div class="card p-4 h-100 step-card text-center border-0 shadow-sm" style="background-color: #FFFFFF; border: 1px solid #E8DDD5 !important;">
                <div class="mb-3">
                    <span class="step-number">2</span>
                </div>
                <h5 style="font-family: 'Times New Roman', serif; font-weight: bold; color: #5C1A1A;">Go Available</h5>
                <p class="text-muted small mb-0" style="color: #8C7B75 !important;">Toggle your availability on to receive matching requests in your area.</p>
            </div>
        </div>
        
        <!-- Step 3 -->
        <div class="col-md-3">
            <div class="card p-4 h-100 step-card text-center border-0 shadow-sm" style="background-color: #FFFFFF; border: 1px solid #E8DDD5 !important;">
                <div class="mb-3">
                    <span class="step-number">3</span>
                </div>
                <h5 style="font-family: 'Times New Roman', serif; font-weight: bold; color: #5C1A1A;">Connect</h5>
                <p class="text-muted small mb-0" style="color: #8C7B75 !important;">Requesters match with you and reach out directly to coordinate.</p>
            </div>
        </div>
        
        <!-- Step 4 -->
        <div class="col-md-3">
            <div class="card p-4 h-100 step-card text-center border-0 shadow-sm" style="background-color: #FFFFFF; border: 1px solid #E8DDD5 !important;">
                <div class="mb-3">
                    <span class="step-number">4</span>
                </div>
                <h5 style="font-family: 'Times New Roman', serif; font-weight: bold; color: #5C1A1A;">Save Lives</h5>
                <p class="text-muted small mb-0" style="color: #8C7B75 !important;">Complete your donation at the medical facility and make an impact.</p>
            </div>
        </div>
    </div>
</div>

<!-- Statistics Row -->
<div class="card p-4 my-5 border-0 shadow-sm" style="background-color: #FAF6F0; border: 1px solid #E8DDD5 !important;">
    <div class="row text-center g-4">
        <div class="col-6 col-md-3">
            <h2 class="display-5 fw-bold mb-0" style="color: #9B3A3A;">10K+</h2>
            <small class="text-uppercase text-muted" style="letter-spacing: 1px;">Registered Donors</small>
        </div>
        <div class="col-6 col-md-3">
            <h2 class="display-5 fw-bold mb-0" style="color: #9B3A3A;">4.8K+</h2>
            <small class="text-uppercase text-muted" style="letter-spacing: 1px;">Lives Impacted</small>
        </div>
        <div class="col-6 col-md-3">
            <h2 class="display-5 fw-bold mb-0" style="color: #9B3A3A;">15+</h2>
            <small class="text-uppercase text-muted" style="letter-spacing: 1px;">Hospital Partners</small>
        </div>
        <div class="col-6 col-md-3">
            <h2 class="display-5 fw-bold mb-0" style="color: #9B3A3A;">100%</h2>
            <small class="text-uppercase text-muted" style="letter-spacing: 1px;">Voluntary & Free</small>
        </div>
    </div>
</div>
