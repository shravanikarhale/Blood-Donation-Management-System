@model IEnumerable<BloodDonationApp.Models.BloodRequest>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Manage Blood Requests";
}

<div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
    <h1 style="font-family: 'Times New Roman', serif;">Manage Blood Requests</h1>
    <span class="badge bg-danger py-2 px-3 text-uppercase">Admin Portal</span>
</div>

<div class="card border-0 shadow-sm p-4">
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Patient Name</th>
                    <th>Blood Type</th>
                    <th>Units</th>
                    <th>Hospital</th>
                    <th>City</th>
                    <th>Required Date</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var request in Model)
                {
                    <tr>
                        <td>
                            <strong>@request.PatientName</strong>
                            <br /><small class="text-muted">Contact: @request.ContactNumber</small>
                        </td>
                        <td>
                            <span class="badge bg-danger fs-6">@request.BloodType</span>
                        </td>
                        <td>@request.Units Unit(s)</td>
                        <td>@request.Hospital</td>
                        <td>@request.City</td>
                        <td>@request.RequiredDate.ToString("yyyy-MM-dd")</td>
                        <td>
                            <span class="badge @(request.Status == "Emergency" ? "bg-danger" : request.Status == "Approved" ? "bg-success" : request.Status == "Rejected" ? "bg-secondary" : "bg-warning") p-2 text-uppercase">
                                @request.Status
                            </span>
                        </td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end gap-1">
                                @if (request.Status == "Pending")
                                {
                                    <form asp-action="ApproveRequest" asp-route-id="@request.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-success text-uppercase py-1">Approve</button>
                                    </form>
                                    <form asp-action="RejectRequest" asp-route-id="@request.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger text-uppercase py-1">Reject</button>
                                    </form>
                                    <form asp-action="MakeEmergency" asp-route-id="@request.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-danger text-uppercase py-1">Emergency</button>
                                    </form>
                                }
                                else if (request.Status == "Emergency")
                                {
                                    <form asp-action="ApproveRequest" asp-route-id="@request.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-success text-uppercase py-1">Approve</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted small">No actions</span>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
