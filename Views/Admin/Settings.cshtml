@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin Settings";
}

<div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
    <h1 style="font-family: 'Times New Roman', serif;">Portal Settings</h1>
    <span class="badge bg-secondary py-2 px-3 text-uppercase">Admin Configuration</span>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm p-4">
            <h3 style="font-family: 'Times New Roman', serif;" class="mb-4">System Parameters</h3>
            
            <form onclick="alert('Settings saved successfully!'); return false;">
                <div class="mb-3">
                    <label class="form-label text-uppercase small fw-bold" style="color: #C0392B; letter-spacing: 1px;">Platform Name</label>
                    <input type="text" class="form-control" value="Donora Blood Management" />
                </div>
                
                <div class="mb-3">
                    <label class="form-label text-uppercase small fw-bold" style="color: #C0392B; letter-spacing: 1px;">Admin Notification Email</label>
                    <input type="email" class="form-control" value="admin@blood.org" />
                </div>
                
                <div class="form-check mb-4 mt-3">
                    <input class="form-check-input" type="checkbox" id="flexCheckChecked" checked>
                    <label class="form-check-label text-uppercase small fw-bold" style="color: #E67E22; letter-spacing: 1px;" for="flexCheckChecked">
                        Enable Automatic Emergency Broadcast Notifications
                    </label>
                </div>
                
                <button type="submit" class="btn btn-primary text-uppercase px-4">Save Configuration</button>
            </form>
        </div>
    </div>
</div>
