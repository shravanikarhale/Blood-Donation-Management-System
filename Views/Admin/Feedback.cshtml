@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "User Feedback & Helpdesk";
}

<div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
    <h1 style="font-family: 'Times New Roman', serif;">User Feedback & Helpdesk</h1>
    <span class="badge bg-secondary py-2 px-3 text-uppercase">Helpdesk Queue</span>
</div>

<div class="card border-0 shadow-sm p-4">
    <h3 style="font-family: 'Times New Roman', serif;" class="mb-4 text-dark">Awaiting Reply</h3>
    
    <div class="list-group">
        <div class="list-group-item list-group-item-action flex-column align-items-start p-3 mb-3 border rounded shadow-sm">
            <div class="d-flex w-100 justify-content-between">
                <h5 class="mb-1 text-danger">Issue: Booking error on profile page</h5>
                <small class="text-muted">1 hour ago</small>
            </div>
            <p class="mb-1">"I tried to update my last donation date, but the date picker says the value is invalid. Can you please check?"</p>
            <small class="text-muted">Sent by: <strong>Jane Smith</strong> (jane@example.com)</small>
            <div class="mt-3">
                <textarea class="form-control mb-2" rows="2" placeholder="Write admin response..."></textarea>
                <button class="btn btn-sm btn-primary text-uppercase" onclick="alert('Reply sent successfully!'); this.parentElement.parentElement.remove();">Submit Response</button>
            </div>
        </div>
        
        <div class="list-group-item list-group-item-action flex-column align-items-start p-3 border rounded shadow-sm">
            <div class="d-flex w-100 justify-content-between">
                <h5 class="mb-1 text-danger">Question: Availability status badge</h5>
                <small class="text-muted">1 day ago</small>
            </div>
            <p class="mb-1">"Is there a limit to how many times I can toggle my availability?"</p>
            <small class="text-muted">Sent by: <strong>Robert Brown</strong> (robert@example.com)</small>
            <div class="mt-3">
                <textarea class="form-control mb-2" rows="2" placeholder="Write admin response..."></textarea>
                <button class="btn btn-sm btn-primary text-uppercase" onclick="alert('Reply sent successfully!'); this.parentElement.parentElement.remove();">Submit Response</button>
            </div>
        </div>
    </div>
</div>
