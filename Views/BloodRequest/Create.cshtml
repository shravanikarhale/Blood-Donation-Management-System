@model BloodDonationApp.Models.BloodRequest
@{
    Layout = "_UserLayout";
    ViewData["Title"] = "Request Blood";
}

<div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
    <h1 style="font-family: 'Times New Roman', serif;">Request Blood</h1>
    <a asp-controller="Donor" asp-action="Dashboard" class="btn btn-secondary btn-sm">&larr; Back to Dashboard</a>
</div>

<div class="row">
    <div class="col-md-7">
        <div class="card border-0 shadow-sm p-4">
            <h3 style="font-family: 'Times New Roman', serif;" class="mb-3 text-dark">Submit a Blood Request</h3>
            <p class="text-muted small mb-4">
                Fill in the details below. Once submitted, your request will be flagged as <strong>Pending</strong> and reviewed by the platform administrators.
            </p>
            
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                
                <div class="row">
                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="PatientName" class="control-label text-uppercase small fw-bold" style="color: #C0392B; letter-spacing: 1.5px;">Patient Name</label>
                        <input asp-for="PatientName" class="form-control" required placeholder="e.g. Mike Wilson" />
                        <span asp-validation-for="PatientName" class="text-danger small"></span>
                    </div>
                    
                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="BloodType" class="control-label text-uppercase small fw-bold" style="color: #C0392B; letter-spacing: 1.5px;">Blood Type Required</label>
                        <select asp-for="BloodType" class="form-control" required>
                            <option value="">-- Select Blood Type --</option>
                            <option value="A+">A+</option>
                            <option value="A-">A-</option>
                            <option value="B+">B+</option>
                            <option value="B-">B-</option>
                            <option value="AB+">AB+</option>
                            <option value="AB-">AB-</option>
                            <option value="O+">O+</option>
                            <option value="O-">O-</option>
                        </select>
                        <span asp-validation-for="BloodType" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="Units" class="control-label text-uppercase small fw-bold" style="color: #C0392B; letter-spacing: 1.5px;">Units Required</label>
                        <input asp-for="Units" class="form-control" type="number" min="1" required placeholder="e.g. 2" />
                        <span asp-validation-for="Units" class="text-danger small"></span>
                    </div>
                    
                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="ContactNumber" class="control-label text-uppercase small fw-bold" style="color: #C0392B; letter-spacing: 1.5px;">Contact Phone Number</label>
                        <input asp-for="ContactNumber" class="form-control" required placeholder="e.g. 9998887777" />
                        <span asp-validation-for="ContactNumber" class="text-danger small"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="Hospital" class="control-label text-uppercase small fw-bold" style="color: #C0392B; letter-spacing: 1.5px;"></label>
                        <input asp-for="Hospital" class="form-control" required placeholder="e.g. City General Hospital" />
                        <span asp-validation-for="Hospital" class="text-danger small"></span>
                    </div>
                    
                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="City" class="control-label text-uppercase small fw-bold" style="color: #C0392B; letter-spacing: 1.5px;"></label>
                        <input asp-for="City" class="form-control" required placeholder="e.g. Los Angeles" />
                        <span asp-validation-for="City" class="text-danger small"></span>
                    </div>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="RequiredDate" class="control-label text-uppercase small fw-bold" style="color: #C0392B; letter-spacing: 1.5px;">Required Date</label>
                    <input asp-for="RequiredDate" class="form-control" type="date" required />
                    <span asp-validation-for="RequiredDate" class="text-danger small"></span>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary w-100 py-3 text-uppercase">Submit Blood Request</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
