@{
    ViewData["Title"] = "Donor Login - Donora";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-md border-0" style="background-color: #FFFFFF; border: 1px solid #E8DDD5 !important; box-shadow: 0 2px 16px rgba(0,0,0,0.07) !important;">
                <div class="card-header text-center py-4" style="background-color: #7D2B2B !important; border-bottom: 2px solid #B5894A !important;">
                    <h2 class="mb-0" style="color: #F5ECD7; font-family: 'Times New Roman', serif; letter-spacing: 2px;">D O N O R A</h2>
                    <small class="text-uppercase" style="color: #B5894A; letter-spacing: 1px;">Donor Portal</small>
                </div>
                <div class="card-body p-4">
                    <h4 class="text-center mb-4" style="font-family: 'Times New Roman', serif; font-style: italic; color: #5C1A1A;">Sign In to Your Dashboard</h4>
                    
                    <form asp-action="UserLogin" method="post">
                        @Html.AntiForgeryToken()
                        
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-3">
                            <label class="control-label text-uppercase small fw-bold" style="color: #9B3A3A; letter-spacing: 1px;">Registered Email</label>
                            <input name="email" class="form-control" type="email" placeholder="e.g. john@example.com" required />
                        </div>
                        
                        <div class="form-group mb-4">
                            <label class="control-label text-uppercase small fw-bold" style="color: #9B3A3A; letter-spacing: 1px;">Password</label>
                            <div class="input-group">
                                <input name="password" id="txtPassword" class="form-control" type="password" placeholder="••••••••" required />
                                <button class="btn btn-outline-secondary" type="button" id="btnTogglePassword" style="border: 1px solid rgba(155, 58, 58, 0.2); border-left: none;">
                                    <i class="bi bi-eye-slash" id="eyeIcon"></i>
                                </button>
                            </div>
                        </div>
                        
                        <div class="form-group">
                            <button type="submit" class="btn btn-primary w-100 py-2">Enter Portal</button>
                        </div>
                    </form>
                    
                    <div class="mt-4 text-center">
                        <p class="mb-1 text-muted small" style="color: #8C7B75 !important;">Don't have an account?</p>
                        <a asp-controller="Donor" asp-action="Register" class="btn btn-secondary btn-sm py-1 px-3 text-uppercase">Register as Donor</a>
                        <div class="mt-3">
                            <a href="/" class="small" style="color: #B5894A; text-decoration: none; font-weight: bold;">&larr; Back to Landing Page</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
